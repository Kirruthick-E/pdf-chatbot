# LLM Provider: "gemini" | "anthropic" | "ollama"
LLM_PROVIDER=gemini

# Model name (provider-specific default used if omitted)
# Gemini default: gemini-2.0-flash
# Anthropic default: claude-haiku-4-5-20251001
# Ollama default: gemma3
LLM_MODEL=gemini-2.0-flash

# API keys (only the one matching LLM_PROVIDER is required)
GEMINI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here

# Ollama base URL (for self-hosted models like Gemma, Llama)
OLLAMA_BASE_URL=http://localhost:11434
