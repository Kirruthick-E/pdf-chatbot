# LLM Provider: "gemini" | "ollama"
LLM_PROVIDER=gemini

# Model name (provider-specific default used if omitted)
# Gemini default: gemini-2.5-flash
# Ollama default: gemma4:e4b
LLM_MODEL=

# API keys (only the one matching LLM_PROVIDER is required)
GEMINI_API_KEY=your_key_here

# Ollama base URL (for self-hosted models like Gemma, Llama)
OLLAMA_BASE_URL=http://localhost:11434

# HuggingFace token — optional for public sentence-transformers, raises rate limits
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# Embedding model — must match a key in embeddings.AVAILABLE_MODELS
#   all-MiniLM-L6-v2   (Fast, ~90 MB)       <- default
#   all-MiniLM-L12-v2  (Balanced, ~120 MB)
#   all-mpnet-base-v2  (High quality, ~420 MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2
